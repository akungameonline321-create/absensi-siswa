# ============================================
# KONFIGURASI SERVER
# ============================================
PORT=5000
NODE_ENV=development

# ============================================
# MYSQL (via Laragon)
# ============================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=absensi_sma

# ============================================
# MONGODB ATLAS
# Ganti <user>, <password>, dan <cluster> sesuai akun Atlas Anda.
# ============================================
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/absensi_sma?retryWrites=true&w=majority

# ============================================
# JWT SECRET (untuk autentikasi — dipakai di langkah selanjutnya)
# ============================================
JWT_SECRET=ganti_dengan_secret_key_yang_kuat

# ============================================
# URL ML ENGINE (microservice Python)
# ============================================
ML_ENGINE_URL=http://localhost:8000
